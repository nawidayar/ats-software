# ----------------------------------------------------------------------------
# TEMPLATE for your secret Supabase keys.
#
# Copy this file and rename the copy to ".env.local", then paste your real
# values in. The real ".env.local" file is kept PRIVATE (Git ignores it),
# so your keys never get shared or uploaded.
#
# Where to find these values:
#   1. Go to https://supabase.com and create a free account + a new project.
#   2. In your project: Settings -> API.
#   3. Copy "Project URL" into NEXT_PUBLIC_SUPABASE_URL.
#   4. Copy the "anon public" key into NEXT_PUBLIC_SUPABASE_ANON_KEY.
# ----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
